<UserControl x:Class="qlks_app.views.QuanLiPhong_View"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:viewModel="clr-namespace:qlks_app.view_model"
			 mc:Ignorable="d"
			 d:DesignHeight="450" d:DesignWidth="800">
	
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
		<SolidColorBrush x:Key="AccentColor" Color="#3498DB"/>
		<SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>
		<SolidColorBrush x:Key="DangerColor" Color="#E74C3C"/>
		<SolidColorBrush x:Key="WarningColor" Color="#F39C12"/>
		<SolidColorBrush x:Key="BackgroundColor" Color="#ECF0F1"/>

		<Style x:Key="PrimaryButton" TargetType="Button">
			<Setter Property="Background" Value="{StaticResource AccentColor}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Height" Value="35"/>
			<Setter Property="Width" Value="100"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Margin" Value="5"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#2980B9"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="SuccessButton" TargetType="Button">
			<Setter Property="Background" Value="{StaticResource SuccessColor}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Height" Value="35"/>
			<Setter Property="Width" Value="100"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Margin" Value="5"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#229954"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style TargetType="TextBox">
			<Setter Property="Height" Value="35"/>
			<Setter Property="Margin" Value="5"/>
			<Setter Property="Padding" Value="10,0"/>
			<Setter Property="BorderBrush" Value="#BDC3C7"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="FontSize" Value="14"/>
		</Style>

		<Style TargetType="ComboBox">
			<Setter Property="Height" Value="35"/>
			<Setter Property="Margin" Value="5"/>
			<Setter Property="Padding" Value="5"/>
			<Setter Property="FontSize" Value="14"/>
		</Style>
	</UserControl.Resources>
	
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Background="White" CornerRadius="10"
                Padding="20" Margin="0,0,0,20">
			<StackPanel>
				<TextBlock Text="🏨 QUẢN LÝ PHÒNG"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryColor}"/>
				<TextBlock Text="Quản lý danh sách phòng, thêm mới và chỉnh sửa thông tin phòng"
                           FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0"/>
			</StackPanel>
		</Border>

		<!-- Toolbar -->
		<Border Grid.Row="1" Background="White" CornerRadius="10"
                Padding="20" Margin="0,0,0,20">
			<Grid>
               <Grid.RowDefinitions>
					  <RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Button Toolbar -->
				<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <Button x:Name="BtnAddRoom" Command="{Binding ThemPhongCommand}"
                            Style="{StaticResource SuccessButton}" Width="120">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="➕ " FontSize="14"/>
							<TextBlock Text="Thêm phòng mới" FontSize="13"/>
						</StackPanel>
					</Button>

                    <Button x:Name="BtnEditRoom" Command="{Binding SuaPhongCommand}"
                            Style="{StaticResource PrimaryButton}" Width="100">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="✏️ " FontSize="14"/>
							<TextBlock Text="Sửa" FontSize="13"/>
						</StackPanel>
					</Button>

                    <Button x:Name="BtnDeleteRoom" Command="{Binding XoaPhongCommand}"
                            Style="{StaticResource PrimaryButton}" Width="100"
                            Background="{StaticResource DangerColor}">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="🗑️ " FontSize="14"/>
							<TextBlock Text="Xóa" FontSize="13"/>
						</StackPanel>
					</Button>

					<Button x:Name="BtnDetailRoom" Command="{Binding ChiTietPhongCommand}"
							Style="{StaticResource PrimaryButton}" Width="110">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="ℹ️ " FontSize="14"/>
							<TextBlock Text="Chi tiết" FontSize="13"/>
						</StackPanel>
					</Button>

					<TextBox x:Name="TxtSearch" Width="250"
                             Tag="🔍 Tìm kiếm phòng..."
                             Margin="20,5,5,5"/>
				</StackPanel>

				<!-- Form thêm/sửa phòng -->
				<Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8"
                        Padding="15" Margin="0,10,0,20"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        x:Name="RoomFormPanel"
						Visibility="{Binding HienThiForm, Converter={StaticResource BooleanToVisibilityConverter}}">

					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="120"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Số phòng:" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtRoomNumber" Grid.Row="0" Grid.Column="1"
								 Width="200" HorizontalAlignment="Left"
								 Text="{Binding SoPhong, UpdateSourceTrigger=PropertyChanged}"/>

						<TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="Loại phòng:" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                     <ComboBox x:Name="CboRoomType" Grid.Row="0" Grid.Column="3"
								  Width="200" HorizontalAlignment="Left"
								  ItemsSource="{Binding DanhSachLoaiPhong}"
								  DisplayMemberPath="TenLoai"
								  SelectedItem="{Binding LoaiPhongDuocChon, UpdateSourceTrigger=PropertyChanged}"/>

						<TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Giá/đêm:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox x:Name="TxtPrice" Grid.Row="1" Grid.Column="1"
								 Width="200" HorizontalAlignment="Left" Margin="0,10,0,0"
								 Text="{Binding GiaMoiDem, UpdateSourceTrigger=PropertyChanged}"/>

						<TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="Trạng thái:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <ComboBox x:Name="CboStatus" Grid.Row="1" Grid.Column="3"
								  Width="200" HorizontalAlignment="Left" Margin="0,10,0,0"
								  ItemsSource="{Binding DanhSachTrangThai}"
								  SelectedItem="{Binding TrangThai, UpdateSourceTrigger=PropertyChanged}"/>

						<TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Sức chứa:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox x:Name="TxtCapacity" Grid.Row="2" Grid.Column="1"
								 Width="200" HorizontalAlignment="Left" Margin="0,10,0,0"
								 Text="{Binding SucChua, UpdateSourceTrigger=PropertyChanged}"/>

						<TextBlock Grid.Row="2" Grid.Column="2"
                                   Text="Mô tả:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox x:Name="TxtDescription" Grid.Row="2" Grid.Column="3"
								 Height="60" TextWrapping="Wrap"
								 Margin="0,10,0,0"
								 Text="{Binding MoTa, UpdateSourceTrigger=PropertyChanged}"/>

                      <TextBlock Grid.Row="3" Grid.Column="0"
								   Text="Ngày checkin:" FontWeight="Bold"
								   VerticalAlignment="Center" Margin="0,10,0,0"/>
						<DatePicker Grid.Row="3" Grid.Column="1"
								   SelectedDate="{Binding NgayCheckin, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,10,0,0"
								   IsEnabled="{Binding ChoPhepChinhSuaNgay}"/>

						<TextBlock Grid.Row="3" Grid.Column="2"
								   Text="Ngày checkout:" FontWeight="Bold"
								   VerticalAlignment="Center" Margin="0,10,0,0"/>
						<DatePicker Grid.Row="3" Grid.Column="3"
								   SelectedDate="{Binding NgayCheckout, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,10,0,0"
								   IsEnabled="{Binding ChoPhepChinhSuaNgay}"/>

						<!-- Form buttons -->
						<StackPanel Grid.Row="4" Grid.ColumnSpan="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button x:Name="BtnSaveRoom" Command="{Binding LuuPhongCommand}"
									Style="{StaticResource SuccessButton}" Content="💾 Lưu"/>
							<Button x:Name="BtnCancelRoom" Command="{Binding HuyPhongCommand}"
									Style="{StaticResource PrimaryButton}" Content="❌ Hủy"
									Background="{StaticResource DangerColor}"/>
						</StackPanel>
					</Grid>
				</Border>

				<!-- DataGrid danh sách phòng -->
                <DataGrid x:Name="DgvRooms" Grid.Row="2"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F9F9F9"
                          RowHeight="45"
						  FontSize="13"
						  ItemsSource="{Binding DanhSachPhong}"
						  SelectedItem="{Binding PhongDangChon, Mode=TwoWay}">

					<DataGrid.Columns>
                   <DataGridTextColumn Header="Mã phòng" Binding="{Binding Id}" Width="80"/>
					<DataGridTextColumn Header="Số phòng" Binding="{Binding SoPhong}" Width="100"/>
					<DataGridTextColumn Header="Loại phòng" Binding="{Binding LoaiPhong.TenLoai}" Width="120"/>
					<DataGridTextColumn Header="Giá/đêm" Binding="{Binding GiaMoiDem, StringFormat=N0}" Width="120"/>
					<DataGridTextColumn Header="Sức chứa" Binding="{Binding SucChua}" Width="80"/>
						<DataGridTemplateColumn Header="Trạng thái" Width="120">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
                              <Border CornerRadius="5" Padding="5,2"
											Background="{Binding MauTrangThai}">
									<TextBlock Text="{Binding TrangThai}"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"/>
									</Border>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
                       <DataGridTextColumn Header="Mô tả" Binding="{Binding MoTa}" Width="200"/>
                        <DataGridTextColumn Header="Ngày checkin" Binding="{Binding NgayCheckin, StringFormat=dd/MM/yyyy}" Width="120"/>
						<DataGridTextColumn Header="Ngày checkout" Binding="{Binding NgayCheckout, StringFormat=dd/MM/yyyy}" Width="120"/>
					</DataGrid.Columns>
             </DataGrid>

				<Border Grid.Row="3" Background="#F8F9FA" CornerRadius="8"
						Padding="15" Margin="0,15,0,0"
						BorderBrush="#E0E0E0" BorderThickness="1"
						Visibility="{Binding HienThiChiTiet, Converter={StaticResource BooleanToVisibilityConverter}}">
					<StackPanel>
						<TextBlock Text="ℹ️ CHI TIẾT PHÒNG" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<TextBlock Grid.Column="0" Text="Số phòng:" FontWeight="Bold"/>
							<TextBlock Grid.Column="1" Text="{Binding PhongDangChon.SoPhong}"/>
							<TextBlock Grid.Column="2" Text="Loại phòng:" FontWeight="Bold"/>
							<TextBlock Grid.Column="3" Text="{Binding PhongDangChon.LoaiPhong.TenLoai}"/>

							<TextBlock Grid.Column="0" Grid.Row="1" Text="Giá/đêm:" FontWeight="Bold" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding PhongDangChon.GiaMoiDem, StringFormat=N0}" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="2" Grid.Row="1" Text="Sức chứa:" FontWeight="Bold" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="3" Grid.Row="1" Text="{Binding PhongDangChon.SucChua}" Margin="0,6,0,0"/>
						</Grid>

                        <Grid Margin="0,0,0,10">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<TextBlock Grid.Column="0" Text="Khách hàng:" FontWeight="Bold"/>
							<TextBlock Grid.Column="1" Text="{Binding KhachHangChiTiet.HoTen}"/>
							<TextBlock Grid.Column="2" Text="Điện thoại:" FontWeight="Bold"/>
							<TextBlock Grid.Column="3" Text="{Binding KhachHangChiTiet.DienThoai}"/>

							<TextBlock Grid.Column="0" Grid.Row="1" Text="Địa chỉ:" FontWeight="Bold" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding KhachHangChiTiet.DiaChi}" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="2" Grid.Row="1" Text="Checkin:" FontWeight="Bold" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="3" Grid.Row="1" Text="{Binding DatPhongChiTiet.NgayCheckin, StringFormat=dd/MM/yyyy}" Margin="0,6,0,0"/>

							<TextBlock Grid.Column="0" Grid.Row="2" Text="Checkout:" FontWeight="Bold" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding DatPhongChiTiet.NgayCheckout, StringFormat=dd/MM/yyyy}" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="2" Grid.Row="2" Text="Tổng tiền:" FontWeight="Bold" Margin="0,6,0,0"/>
							<TextBlock Grid.Column="3" Grid.Row="2" Text="{Binding DatPhongChiTiet.TongTien, StringFormat=N0}" Margin="0,6,0,0"/>
						</Grid>

                       <TextBlock Text="Dịch vụ đã sử dụng" FontWeight="Bold" Margin="0,0,0,5"
								Visibility="{Binding HienThiDichVu, Converter={StaticResource BooleanToVisibilityConverter}}"/>
						<DataGrid AutoGenerateColumns="False"
								ItemsSource="{Binding DanhSachDichVu}"
								IsReadOnly="True"
								RowHeight="35"
								AlternatingRowBackground="#F9F9F9"
								Visibility="{Binding HienThiDichVu, Converter={StaticResource BooleanToVisibilityConverter}}">
							<DataGrid.Columns>
								<DataGridTextColumn Header="Dịch vụ" Binding="{Binding DichVu.TenDichVu}" Width="200"/>
								<DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuong}" Width="80"/>
								<DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTien, StringFormat=N0}" Width="120"/>
								<DataGridTextColumn Header="Ngày dùng" Binding="{Binding NgaySuDung, StringFormat=dd/MM/yyyy}" Width="120"/>
							</DataGrid.Columns>
						</DataGrid>

						<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
							<Button Content="Đóng" Style="{StaticResource PrimaryButton}"
									Command="{Binding DongChiTietCommand}"/>
						</StackPanel>
					</StackPanel>
				</Border>
			</Grid>
		</Border>

		<!-- Footer -->
		<Border Grid.Row="2" Background="White" CornerRadius="10"
                Padding="15" Margin="0,20,0,0">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
				<TextBlock Text="📊 Tổng số phòng: " FontWeight="Bold"/>
                <TextBlock x:Name="TxtTotalRooms" Text="{Binding TongSoPhong}" FontWeight="Bold"
						   Foreground="{StaticResource AccentColor}"/>
				<TextBlock Text=" | Trống: " Margin="20,0,0,0" FontWeight="Bold"/>
                <TextBlock x:Name="TxtAvailableRooms" Text="{Binding SoPhongTrong}" FontWeight="Bold"
						   Foreground="{StaticResource SuccessColor}"/>
				<TextBlock Text=" | Đã đặt: " Margin="20,0,0,0" FontWeight="Bold"/>
                <TextBlock x:Name="TxtBookedRooms" Text="{Binding SoPhongDaDat}" FontWeight="Bold"
						   Foreground="{StaticResource WarningColor}"/>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
