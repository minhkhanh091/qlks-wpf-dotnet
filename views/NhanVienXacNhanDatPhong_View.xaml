<UserControl x:Class="qlks_app.views.NhanVienXacNhanDatPhong_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F39C12"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#ECF0F1"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SuccessColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="✅ XÁC NHẬN ĐẶT PHÒNG" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryColor}"/>
                    <TextBlock Text="Xác nhận các đặt phòng online"
                               FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource SuccessButton}" Width="110"
                            Command="{Binding TaiLaiCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" FontSize="14"/>
                            <TextBlock Text="Làm mới" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}" Width="100"
                            Command="{Binding DongCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❌ " FontSize="14"/>
                            <TextBlock Text="Đóng" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20">
            <Grid Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" AutoGenerateColumns="False" SelectionMode="Single"
                          SelectionUnit="FullRow" IsReadOnly="True" AlternatingRowBackground="#F9F9F9"
                          RowHeight="40" FontSize="13"
                          ItemsSource="{Binding DanhSachDatPhongChoXacNhan}"
                          SelectedItem="{Binding DatPhongDangChon, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Phòng" Binding="{Binding Phong.SoPhong}" Width="90"/>
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding KhachHang.HoTen}" Width="160"/>
                        <DataGridTextColumn Header="Điện thoại" Binding="{Binding KhachHang.DienThoai}" Width="120"/>
                        <DataGridTextColumn Header="Checkin" Binding="{Binding NgayCheckin, StringFormat=dd/MM/yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Checkout" Binding="{Binding NgayCheckout, StringFormat=dd/MM/yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat=N0}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource PrimaryButton}" Width="110"
                                Command="{Binding ChiTietDatPhongCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ℹ️ " FontSize="14"/>
                                <TextBlock Text="Chi tiết" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SuccessButton}" Width="110"
                                Command="{Binding XacNhanDatPhongCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✅ " FontSize="14"/>
                                <TextBlock Text="Xác nhận" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,10,0,0"
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            Visibility="{Binding HienThiChiTiet, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Phòng:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DatPhongChiTiet.Phong.SoPhong}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Loại phòng:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding DatPhongChiTiet.Phong.LoaiPhong.TenLoai}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Khách hàng:" FontWeight="Bold" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding KhachHangChiTiet.HoTen}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Điện thoại:" FontWeight="Bold" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding KhachHangChiTiet.DienThoai}" Margin="0,6,0,0"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Checkin:" FontWeight="Bold" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DatPhongChiTiet.NgayCheckin, StringFormat=dd/MM/yyyy}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Checkout:" FontWeight="Bold" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding DatPhongChiTiet.NgayCheckout, StringFormat=dd/MM/yyyy}" Margin="0,6,0,0"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Style="{StaticResource PrimaryButton}" Width="100"
                                        Command="{Binding DongChiTietCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="❌ " FontSize="14"/>
                                        <TextBlock Text="Đóng" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
