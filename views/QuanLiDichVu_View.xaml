<UserControl x:Class="qlks_app.views.QuanLiDichVu_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F39C12"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#ECF0F1"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SuccessColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="🎯 QUẢN LÝ DỊCH VỤ" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryColor}"/>
                <TextBlock Text="Thêm mới và chỉnh sửa các dịch vụ" FontSize="13"
                           Foreground="#7F8C8D" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Style="{StaticResource SuccessButton}" Width="130"
                            Command="{Binding ThemDichVuCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕ " FontSize="14"/>
                            <TextBlock Text="Thêm dịch vụ" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}" Width="100"
                            Command="{Binding SuaDichVuCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️ " FontSize="14"/>
                            <TextBlock Text="Sửa" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}" Width="110"
                            Command="{Binding TaiLaiCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄 " FontSize="14"/>
                            <TextBlock Text="Làm mới" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,10,0,20"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        Visibility="{Binding HienThiForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tên dịch vụ:" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TenDichVu, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Đơn giá:" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding DonGia, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Đơn vị tính:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DonViTinh, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>

                        <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Style="{StaticResource SuccessButton}" Width="100"
                                    Command="{Binding LuuDichVuCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾 " FontSize="14"/>
                                    <TextBlock Text="Lưu" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Width="100"
                                    Command="{Binding HuyDichVuCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="❌ " FontSize="14"/>
                                    <TextBlock Text="Hủy" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="2" AutoGenerateColumns="False" SelectionMode="Single" SelectionUnit="FullRow"
                          IsReadOnly="True" AlternatingRowBackground="#F9F9F9" RowHeight="40" FontSize="13"
                          ItemsSource="{Binding DanhSachDichVu}"
                          SelectedItem="{Binding DichVuDangChon, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding TenDichVu}" Width="200"/>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat=N0}" Width="120"/>
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonViTinh}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
